NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/fix_my_city
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_RESET_SECRET=replace-with-a-long-reset-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
EMAIL_FROM=no-reply@fixmycity.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
